{
    "name": "syafiq-unijaya/laravel-ai-chatbox",
    "description": "Drop-in AI chatbox widget for Laravel with RAG, streaming, Vue 3 frontend, and support for Ollama, OpenAI, Groq, and any OpenAI-compatible API.",
    "type": "library",
    "keywords": [
        "laravel",
        "laravel-package",
        "chatbot",
        "chatbox",
        "ai",
        "ai-assistant",
        "ai-chatbot",
        "ollama",
        "openai",
        "openai-compatible",
        "groq",
        "lm-studio",
        "widget",
        "llm",
        "chat",
        "rag",
        "retrieval-augmented-generation",
        "embeddings",
        "vector-search",
        "streaming",
        "server-sent-events",
        "sse",
        "vue3",
        "knowledge-base",
        "local-ai"
    ],
    "homepage": "https://github.com/syafiq-unijaya/laravel-ai-chatbox",
    "license": "MIT",
    "authors": [
        {
            "name": "Syafiq Unijaya",
            "email": "syafiqazwan.unijaya@gmail.com",
            "homepage": "https://github.com/syafiq-unijaya",
            "role": "Developer"
        }
    ],
    "support": {
        "issues": "https://github.com/syafiq-unijaya/laravel-ai-chatbox/issues",
        "source": "https://github.com/syafiq-unijaya/laravel-ai-chatbox"
    },
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/routing": "^10.0|^11.0|^12.0",
        "illuminate/http": "^10.0|^11.0|^12.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "SyafiqUnijaya\\AiChatbox\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SyafiqUnijaya\\AiChatbox\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5",
        "orchestra/testbench": "^10.0"
    },
    "scripts": {
        "test": "phpunit"
    },
    "extra": {
        "laravel": {
            "providers": [
                "SyafiqUnijaya\\AiChatbox\\AiChatboxServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
